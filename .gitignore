# .gitignore

# nvim 插件和 lock 文件（会由 lazy.nvim 自动生成）
nvim/lazy-lock.json
nvim/plugin/
nvim/.netrwhist

# yazi 运行时状态（每台机子独立）
yazi/state/

# 备份文件
*.bak
*.bak.*

# 系统
.DS_Store
Thumbs.db
desktop.ini

# 编辑器
.vscode/
.idea/
*.swp
*~

# 本地覆盖（用户可以自己建这些文件做本地微调，不应进版本库）
*.local.lua
*.local.toml
*.local.ps1
*.local.sh
local.*
